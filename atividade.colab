            "text/html": [
              "\n",
              "     <input type=\"file\" id=\"files-069fb4f4-5f3e-4202-833b-2e4bc2d69e1a\" name=\"files[]\" multiple disabled\n",
              "        style=\"border:none\" />\n",
              "     <output id=\"result-069fb4f4-5f3e-4202-833b-2e4bc2d69e1a\">\n",
              "      Upload widget is only available when the cell has been executed in the\n",
