      "cell_type": "code",
      "source": [
        "from sklearn.metrics import classification_report\n",
        "\n",
        "y_pred_dl = (model.predict(X_test) > 0.5).astype(int)\n",
        "\n",
        "print(classification_report(y_test, y_pred_dl))"
